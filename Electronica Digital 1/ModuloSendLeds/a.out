    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x5a3f064ec490;
T_1 ;
    %vpi_call 2 13 "$display", "=== TESTBENCH MEMORIA DE LEDs ===" {0 0 0};
    %pushi/vec4 0, 0, 32;
